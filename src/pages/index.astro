---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CampSection from '../components/CampSection.astro';
import CatalogueGrid from '../components/CatalogueGrid.astro';
import LanguageCard from '../components/LanguageCard.astro';
import starsData from '../data/stars.json';
import {
  campsIntro,
  camps,
  methodology,
  withCampSpans,
  inlineMarkdownToHtml,
} from '../data/homepage-copy';

const languages = await getCollection('languages');

const byCamp = (camp: string) => languages.filter((l) => l.data.camp === camp);

const syntactic = byCamp('syntactic');
const verification = byCamp('verification');
const orchestration = byCamp('orchestration');
const adjacent = byCamp('adjacent');
const unclassified = byCamp('unclassified');

const mainCatalogue = [...syntactic, ...verification, ...orchestration];
const sideCatalogue = [...adjacent, ...unclassified];

const findById = (id: string) => {
  const entry = languages.find((l) => l.id === id);
  if (!entry) throw new Error(`Missing required language entry: ${id}`);
  return entry;
};

const magpie = findById('magpie');
const vera = findById('vera');
const boruna = findById('boruna');

const stars = starsData as Record<string, { stars?: number; forks?: number; fetched_at?: string }>;

const monthNames = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
const buildDate = new Date();
const asOfLabel = `${buildDate.getDate()} ${monthNames[buildDate.getMonth()]} ${buildDate.getFullYear()}`;

const trackedCount = languages.length;
---
<Base
  title="agentlanguages.dev — Programming languages designed for AI agents to write"
  description="A community-edited catalogue of programming languages designed for AI agents to author code, organised around three philosophical camps: syntactic, verification, and orchestration."
>
  <section class="hero">
    <div class="col col-wide">
      <div class="eyebrow"><span class="sec">§</span> as of {asOfLabel} · {trackedCount} languages tracked</div>
      <h1>Programming languages designed for AI agents <em>to write</em>.</h1>
      <p class="lead">A live catalogue of an emerging field. {trackedCount} projects, three camps, and a foundational argument about how to frame the problem itself.</p>
      <p class="citation">Originally catalogued in a post <a href="https://negroniventurestudios.com/2026/05/20/three-camps-alike-in-dignity/">&ldquo;Three camps alike in dignity&rdquo;</a> written for the Negroni Venture Studios blog.</p>
    </div>
  </section>

  <section class="camps-intro" id="camps">
    <div class="col col-wide">
      <div class="eyebrow"><span class="sec">§ 01</span> · the taxonomy</div>
      <h2>{campsIntro.heading}</h2>
      <p set:html={withCampSpans(campsIntro.body)}></p>
    </div>
  </section>

  <CampSection
    camp="syntactic"
    sectionNumber="02"
    campLabel="the representational camp"
    campTitle="Syntactic."
    thesis={camps.syntactic.thesis}
    anchor={magpie}
    anchorQuote="~2.3× more tokens per operation — and that’s the point."
  >
    {camps.syntactic.paragraphs.map((p) => (<p set:html={inlineMarkdownToHtml(p)}></p>))}
  </CampSection>

  <CampSection
    camp="verification"
    sectionNumber="03"
    campLabel="the semantic camp"
    campTitle="Verification."
    thesis={camps.verification.thesis}
    anchor={vera}
    anchorQuote={camps.verification.thesis}
  >
    {camps.verification.paragraphs.map((p) => (<p set:html={inlineMarkdownToHtml(p)}></p>))}
  </CampSection>

  <CampSection
    camp="orchestration"
    sectionNumber="04"
    campLabel="the coordination camp"
    campTitle="Orchestration."
    thesis={camps.orchestration.thesis}
    anchor={boruna}
    anchorQuote="When a regulator asks what exactly ran, you can prove it."
  >
    {camps.orchestration.paragraphs.map((p) => (<p set:html={inlineMarkdownToHtml(p)}></p>))}
  </CampSection>

  <section class="catalogue" id="catalogue">
    <div class="col col-full">
      <div class="eyebrow"><span class="sec">§ 05</span> · the full catalogue</div>
      <h2>The full set.</h2>
      <p class="sub">Every language designed for LLMs or agents to author code, as of {asOfLabel}.</p>
      <CatalogueGrid languages={mainCatalogue} stars={stars} />
    </div>
  </section>

  <section class="adjacent">
    <div class="col col-full">
      <div class="eyebrow"><span class="sec">§ 06</span> · adjacent &amp; unclassified</div>
      <h2>Related work.</h2>
      <p class="sub">Infrastructure that operates around these languages, or candidates that haven&rsquo;t shipped enough to classify.</p>
      <div class="grid">
        {sideCatalogue.map((lang) => (
          <LanguageCard
            language={lang}
            stars={lang.data.repo ? stars[lang.data.repo]?.stars ?? null : null}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="about" id="about">
    <div class="col col-wide">
      <div class="eyebrow"><span class="sec">§ 07</span> · about this catalogue</div>
      <h2>Methodology.</h2>
      <p class="lead" set:html={inlineMarkdownToHtml(methodology.lead)}></p>

      <div class="columns">
        <div>
          <h3>{methodology.whatCounts.heading}</h3>
          {methodology.whatCounts.paragraphs.map((p) => (<p set:html={inlineMarkdownToHtml(p)}></p>))}
        </div>
        <div>
          <h3>{methodology.howToContribute.heading}</h3>
          {methodology.howToContribute.paragraphs.map((p) => (<p set:html={inlineMarkdownToHtml(p)}></p>))}
        </div>
      </div>
    </div>
  </section>
</Base>
