---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  campAccent?: 'syntactic' | 'verification' | 'orchestration' | 'adjacent' | 'unclassified';
}

const {
  title,
  description = 'A community-edited catalogue of programming languages designed for AI agents to author code.',
  campAccent,
} = Astro.props;

const bodyStyle = campAccent ? `--camp: var(--camp-${campAccent});` : undefined;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL('/og-image.png', Astro.site).toString();

// Derive the markdown-alternate URL for this page. `/` → `/index.md`,
// `/languages/<slug>/` → `/languages/<slug>.md`. The .md endpoints are
// generated by sibling files under src/pages/ — see index.md.ts and
// languages/[slug].md.ts. Any path that doesn't map gets no alternate
// (e.g. the future contributing/methodology routes, when they exist).
const pathname = Astro.url.pathname;
let markdownAlt: string | null = null;
if (pathname === '/' || pathname === '') {
  markdownAlt = '/index.md';
} else {
  const langMatch = pathname.match(/^\/languages\/([^/]+)\/?$/);
  if (langMatch) markdownAlt = `/languages/${langMatch[1]}.md`;
}
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <!-- ?v= bumps cache-bust the favicon. Chrome/Safari keep a persistent
         favicon database keyed by URL that ignores normal cache headers;
         changing the URL is the only reliable way to force a re-fetch.
         Bump this when the favicon design changes. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <!-- /favicon.ico is the legacy fallback browsers and crawlers request by
         default if no link tag matches. Now a multi-size ICO (16/32/48)
         generated from favicon.svg via scripts/build_favicons.mjs. -->
    <link rel="icon" href="/favicon.ico?v=2" />
    <link rel="sitemap" href="/sitemap.xml" />
    {/* Agent-accessibility. Every HTML page has a markdown companion served on
        the same origin; the catalogue also exposes /llms.txt (short index) and
        /llms-full.txt (concatenated full text). The `rel="llms-txt"` and
        `rel="llms-full-txt"` custom relations come from the llmstxt.org
        community — not in the IANA registry, but emerging as the convention
        agent SDKs look for when `<link rel="alternate">` is ambiguous. */}
    {markdownAlt && (
      <link rel="alternate" type="text/markdown" href={markdownAlt} title="Markdown version of this page" />
    )}
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="llms.txt — catalogue index for AI agents" />
    <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="llms-full.txt — full catalogue text" />
    <link rel="llms-txt" href="/llms.txt" />
    <link rel="llms-full-txt" href="/llms-full.txt" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="agentlanguages.dev — Programming languages designed for AI agents to write" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // System-preference detection lives in CSS now (see the
      // @media (prefers-color-scheme: dark) block in global.css). All this
      // inline script does is apply an explicit user override saved in
      // localStorage — running synchronously in <head> so it lands before
      // first paint and avoids a flash.
      (function () {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || saved === 'light') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      })();
    </script>
  </head>
  <body style={bodyStyle}>
    <Header />
    <slot />
    <Footer />

    <script is:inline>
      // Toggle sets data-theme to "light" or "dark" explicitly — never
      // removes the attribute — so an explicit-light choice on a dark-pref
      // OS still wins. Removing the attribute would re-expose the user to
      // the @media (prefers-color-scheme: dark) rule and flip them back.
      //
      // To pick "follow my OS again", users can clear localStorage (devtools
      // or a future "Reset" button); we don't yet expose a UI for that.
      //
      // The current state is read from the *computed* theme rather than the
      // attribute alone, so the first click on a system-dark page where the
      // attribute is unset still flips correctly to light.
      function toggleTheme() {
        var root = document.documentElement;
        var explicit = root.getAttribute('data-theme');
        var isDark = explicit
          ? explicit === 'dark'
          : window.matchMedia('(prefers-color-scheme: dark)').matches;
        var next = isDark ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      }
    </script>
  </body>
</html>
