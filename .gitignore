# Python virtualenv for scripts/refresh_stars.py (see scripts/refresh_stars.py
# header for setup). Homebrew Python on macOS refuses pip installs at the
# system level (PEP 668), so the script's pyyaml dep lives in a local venv.
.venv/

# Cataloguing-notice toolkit. Operational scaffolding for posting one-time
# notices to the catalogued projects — kept local because the canonical
# artefacts are the GitHub issues those notices create on other repos, not
# the toolkit that produces them. The repo stays focused on editorial
# content (src/content/languages/) rather than the side-effecting tooling.
scripts/post_notices.sh
scripts/notice-template.md
scripts/notices.tsv
scripts/notices.log

# macOS-specific files
.DS_Store

# editors
.idea/
*.swp
*.swo

# working docs (kept local; not part of the public catalogue)
